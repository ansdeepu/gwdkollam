
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin (editor).
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }

    // Helper function to check if the user is an editor or viewer.
    function isEditorOrViewer() {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return userRole == 'editor' || userRole == 'viewer';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read/write any user profile.
      // Users can read/update their own profile.
      allow read, update: if isAdmin() || request.auth.uid == userId;
      // Only admins can create or delete user profiles.
      allow create, delete: if isAdmin();
    }

    // Rules for the 'staffMembers' collection
    match /staffMembers/{staffId} {
      // Any authenticated user can read the staff list.
      // Only admins can create, update, or delete staff members.
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }

    // Rules for the 'gwdRates' collection
    match /gwdRates/{rateId} {
        // Any authenticated user can read the rates.
        // Only admins can create, update, or delete rates.
        allow read: if request.auth.uid != null;
        allow write: if isAdmin();
    }
    
    // Rules for the 'fileEntries' collection
    match /fileEntries/{fileId} {
      // A user can read a file if:
      // 1. They are an editor or a viewer.
      // 2. They are a site manager AND their UID is in the file's 'assignedSupervisorUids' array.
      allow read: if isEditorOrViewer() || (request.auth.uid in resource.data.assignedSupervisorUids);
      
      // A user can write (create/update/delete) a file if:
      // 1. They are an editor.
      allow write: if isAdmin();
    }

    // Default deny all other collections/paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
