
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user has a specific role
    function hasRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    // Helper function to check if user is approved
    function isApproved() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow users to read their own profile.
      // Allow approved editors to read any profile.
      allow read: if request.auth != null && (request.auth.uid == userId || (hasRole('editor') && isApproved()));
      // Allow users to create their own profile upon registration.
      // Allow approved editors to update any profile.
      allow write: if request.auth != null && (request.auth.uid == userId || (hasRole('editor') && isApproved()));
    }

    // Rules for the 'fileEntries' collection
    match /fileEntries/{fileId} {
      // Editors and Viewers can read all file entries.
      // Supervisors can only read files they are assigned to.
      allow read: if request.auth != null && isApproved() && 
                    (hasRole('editor') || hasRole('viewer') || (hasRole('supervisor') && resource.data.assignedSupervisorUids.hasAny([request.auth.uid])));
      
      // Only approved editors can create, update, or delete file entries.
      allow write: if request.auth != null && isApproved() && hasRole('editor');
    }
    
    // Rules for 'staffMembers' collection
    match /staffMembers/{staffId} {
      allow read: if request.auth != null && isApproved();
      allow write: if request.auth != null && isApproved() && hasRole('editor');
    }
    
    // Rules for 'pendingUpdates' collection
    match /pendingUpdates/{updateId} {
       // Supervisors can create updates. Editors can read and write (to approve/reject).
      allow read: if request.auth != null && isApproved() && hasRole('editor');
      allow create: if request.auth != null && isApproved() && hasRole('supervisor');
      allow update, delete: if request.auth != null && isApproved() && hasRole('editor');
    }

    // Rules for 'gwdRates' collection
    match /gwdRates/{rateId} {
      allow read: if request.auth != null && isApproved();
      allow write: if request.auth != null && isApproved() && hasRole('editor');
    }
  }
}
